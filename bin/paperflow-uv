#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_UV="$PROJECT_ROOT/.paperflow/bin/uv"

if [[ -x "$LOCAL_UV" ]]; then
  UV_BINARY="$LOCAL_UV"
elif [[ -n "${PAPERFLOW_SYSTEM_UV:-}" && -x "$PAPERFLOW_SYSTEM_UV" ]]; then
  UV_BINARY="$PAPERFLOW_SYSTEM_UV"
elif command -v uv >/dev/null 2>&1; then
  UV_BINARY="$(command -v uv)"
elif [[ -x /opt/homebrew/bin/uv ]]; then
  UV_BINARY="/opt/homebrew/bin/uv"
else
  echo "PaperFlow could not find uv. Run scripts/bootstrap_uv.sh after installing uv." >&2
  exit 127
fi

export UV_PROJECT_ENVIRONMENT="${UV_PROJECT_ENVIRONMENT:-$PROJECT_ROOT/.venv}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$PROJECT_ROOT/.uv-cache}"
export UV_PYTHON_INSTALL_DIR="${UV_PYTHON_INSTALL_DIR:-$PROJECT_ROOT/.uv-python}"
export UV_TOOL_DIR="${UV_TOOL_DIR:-$PROJECT_ROOT/.uv-tools}"
export UV_NO_ACTIVE_VENV=1
export PYTHONUNBUFFERED=1
export PYTHONIOENCODING=utf-8

if [[ -n "${VIRTUAL_ENV:-}" ]]; then
  ACTIVE_VENV_BIN="$VIRTUAL_ENV/bin"
  PATH=":$PATH:"
  PATH="${PATH//:$ACTIVE_VENV_BIN:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
  export PATH
  unset VIRTUAL_ENV
fi

cd "$PROJECT_ROOT"
exec "$UV_BINARY" "$@"
